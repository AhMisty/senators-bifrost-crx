{
  "name": "@senators/bifrost-crx",
  "version": "1.1.6",
  "private": false,
  "description": "A browser extension for Bifrost, making your interstellar journey easier!",
  "keywords": [
    "@senators/bifrost-crx",
    "senators",
    "bifrost",
    "ogame"
  ],
  "license": "MIT",
  "homepage": "https://github.com/AhMisty/senators-bifrost-crx",
  "repository": {
    "type": "git",
    "url": "https://github.com/AhMisty/senators-bifrost-crx"
  },
  "bugs": {
    "url": "https://github.com/AhMisty/senators-bifrost-crx/issues",
    "email": "AhMisty@outlook.com"
  },
  "author": "AhMisty",
  "type": "module",
  "devDependencies": {
    "@crxjs/vite-plugin": "latest",
    "@types/chrome": "latest",
    "@types/node": "latest",
    "git-cz": "latest",
    "npm-run-all2": "latest",
    "oxfmt": "latest",
    "oxlint": "latest",
    "oxlint-tsgolint": "latest",
    "typescript": "latest",
    "unocss": "latest",
    "vite": "latest",
    "vite-plugin-solid": "latest",
    "vite-plugin-zip-pack": "latest"
  },
  "scripts": {
    "lint": "oxlint . --fix --type-aware --type-check --ignore-path .gitignore",
    "fmt": "oxfmt . --write --ignore-path .gitignore",
    "check": "run-s lint fmt",
    "dev": "vite",
    "preview": "vite preview",
    "git-add": "git add .",
    "git-commit": "git-cz",
    "git-push": "git push",
    "git": "run-s check git-add git-commit git-push",
    "build-only": "vite build",
    "build": "run-s check build-only",
    "push": "run-s build && npm publish --access public"
  },
  "dependencies": {
    "@arwes/solid": "latest",
    "@senators/bifrost": "latest",
    "@solidjs/router": "latest",
    "solid-js": "latest"
  }
}
