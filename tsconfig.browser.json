{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.browser.tsbuildinfo",
    "composite": true,
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "types": ["vite/client", "chrome"],
    "jsx": "preserve",
    "jsxImportSource": "solid-js"
  },
  "include": ["src/ui/**/*", "src/content/**/*", "src/shared/**/*"]
}
